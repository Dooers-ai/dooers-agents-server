# Database (PostgreSQL)
AGENT_DATABASE_HOST=localhost
AGENT_DATABASE_PORT=5432
AGENT_DATABASE_USER=postgres
AGENT_DATABASE_NAME=agents
AGENT_DATABASE_PASSWORD=
AGENT_DATABASE_SSL=

# Observability — Google Cloud Trace
# Set GOOGLE_CLOUD_PROJECT to enable. Requires observability extras:
#   pip install "dooers-agents-server[observability]"
# On Cloud Run, credentials are automatic (ADC). Locally: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=
OTEL_SERVICE_NAME=dooers-agent