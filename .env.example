# Database (PostgreSQL)
AGENT_DATABASE_HOST=localhost
AGENT_DATABASE_PORT=5432
AGENT_DATABASE_USER=postgres
AGENT_DATABASE_NAME=agents
AGENT_DATABASE_PASSWORD=
AGENT_DATABASE_SSL=

# Observability — export turns to dooers-service-otel (requires observability extras):
#   pip install "dooers-agents-server[observability]"
# Both URLs required; when either is empty, tracing stays disabled.
AGENT_CORE_BASE_URL=https://api-v2.dev.dooers.ai
AGENT_OTEL_SERVICE_URL=https://observability.dooers.ai
OTEL_SERVICE_NAME=dooers-agent
